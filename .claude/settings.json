{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(python -m pytest *)",
      "Bash(python -m mypy *)",
      "Bash(python -m ruff *)",
      "Bash(uv run *)",
      "Bash(uv pip *)",
      "Bash(uv sync *)",
      "Bash(pip install *)",
      "Bash(pip list *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "MCP(sonarqube_analyze_file *)",
      "MCP(sonarqube_list_potential_security_issues *)",
      "MCP(sonarqube_exclude_from_analysis *)",
      "MCP(mcp_io_snyk_mcp_snyk_auth_status *)",
      "MCP(mcp_io_snyk_mcp_snyk_auth *)",
      "MCP(mcp_io_snyk_mcp_snyk_code_scan *)",
      "MCP(mcp_io_snyk_mcp_snyk_sca_scan *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  }
}
