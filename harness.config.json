{
  "project": {
    "name": "Stellaris Overmind",
    "description": "LLM-driven Stellaris strategy engine with harness, AI radar, and selfimprove"
  },
  "commands": {
    "lint": "python -m ruff check engine/bridge.py engine/save_reader.py engine/recorder.py engine/setup_wizard.py",
    "lintFix": "npm run lint:fix",
    "typeCheck": "python -m mypy engine/validator.py --disable-error-code type-arg",
    "build": "python -m compileall -q engine scripts tests",
    "test": "python -m pytest -q",
    "testBackend": "npm test",
    "testFrontend": "npm test",
    "testFow": "python -m pytest -q tests -k \"fog or intel or hidden\"",
    "testWhitelist": "python -m pytest -q tests/test_validator.py -k \"action or whitelist or invalid\"",
    "testVersionLock": "python -m pytest -q tests -k \"version or game_version or ruleset\"",
    "testBridgeContract": "python -m pytest -q tests -k \"bridge or recorder or setup_wizard or save_reader\"",
    "metaDetect": "python scripts/scaffold_meta.py --detect",
    "metaList": "python scripts/scaffold_meta.py --list",
    "metaAudit": "python scripts/audit_knowledge.py",
    "metaTests": "python -m pytest -q tests/test_strategic_knowledge.py",
    "versionLockTests": "python -m pytest -q tests -k \"version or game_version or ruleset\"",
    "safetyTests": "python -m pytest -q tests -k \"fog or intel or whitelist or validator\"",
    "empireBuildEval": "python -m training.evaluate --provider stub",
    "actionPolicyEval": "python -m pytest -q tests -k \"validator and action\"",
    "fowSafetyEval": "python -m pytest -q tests -k \"fog or intel or hidden\"",
    "methodRegression": "python -m pytest -q tests -k \"decision_engine or strategic_planner or multi_agent\"",
    "methodScore": "python scripts/score_method.py"
  },
  "models": {
    "implementer": {
      "provider": "github-copilot",
      "model": "gpt-5.3-codex",
      "useFor": [
        "implement",
        "build-fix",
        "test-fix",
        "code edits",
        "targeted refactors"
      ]
    },
    "reviewer": {
      "provider": "anthropic",
      "model": "claude-opus-4.8",
      "useFor": [
        "understand",
        "architect",
        "review-breadth",
        "review-depth",
        "feedback",
        "cross-model review"
      ]
    }
  },
  "graph": {
    "enabled": false,
    "pluginRoot": "<absolute path to a local Understand-Anything plugin checkout, or leave blank>",
    "path": ".understand-anything/knowledge-graph.json"
  },
  "llm": {
    "provider": "ollama",
    "model": "qwen2.5-coder:14b",
    "embedModel": "nomic-embed-text",
    "ollama": {
      "host": "http://localhost:11434"
    },
    "lmstudio": {
      "host": "http://localhost:1234"
    }
  },
  "experiments": {
    "exampleMetricCommand": "ruff check . --statistics",
    "exampleMetricExtract": "(\\\\d+)\\\\s+",
    "exampleTarget": "engine/validator.py"
  },
  "evolve": {
    "evalAgent": "node scripts/harness/ollama-apply-agent.mjs --model qwen2.5-coder:14b",
    "targetFile": ".github/harness/evolve/candidate-instructions.md",
    "description": "Meta-loop for iterative refinement of harness routing guidance based on experiment scoring"
  },
  "traceGrading": {
    "stallAllowance": 1,
    "minGrade": null,
    "strictMode": true,
    "earlyStop": 2,
    "description": "Deterministic trajectory scoring for convergence loops and workflow metrics",
    "scorer": "scripts/harness/grade-trace.mjs"
  },
  "otel": {
    "serviceName": "harness-kit",
    "endpoint": null,
    "localPath": ".github/harness/otel",
    "writeJson": true,
    "description": "OpenTelemetry trace export for observability dashboard",
    "exporter": "scripts/harness/otel-export.mjs"
  },
  "dashboard": {
    "port": 8099,
    "intervalSeconds": 60
  },
  "routing": {
    "defaultMode": "harness-first",
    "requireDistinctReviewerAndImplementer": true,
    "trivialStartsAt": "implement",
    "nonTrivialStages": [
      "understand",
      "architect",
      "implement",
      "review-breadth",
      "review-depth",
      "feedback"
    ],
    "trivialKeywords": [
      "typo",
      "wording",
      "comment",
      "copy",
      "rename",
      "small doc",
      "format"
    ],
    "nonTrivialKeywords": [
      "api",
      "route",
      "schema",
      "entity",
      "migration",
      "database",
      "auth",
      "security",
      "frontend",
      "backend",
      "shared type",
      "infrastructure",
      "docker",
      "azure",
      "ci",
      "review",
      "architecture",
      "loop"
    ],
    "profiles": {
      "feature": {
        "description": "Full feature delivery through the complete stage machine.",
        "mode": "non-trivial",
        "stages": [
          "understand",
          "architect",
          "implement",
          "review-breadth",
          "review-depth",
          "feedback"
        ]
      },
      "review": {
        "description": "Independent review path without an implementation handoff.",
        "mode": "review-only",
        "stages": [
          "understand",
          "review-breadth",
          "review-depth",
          "feedback"
        ]
      }
    }
  },
  "prSize": {
    "baseRef": "origin/main",
    "suggestedLimit": 400,
    "hardLimit": 800,
    "exemptGlobs": [
      "**/*.snap",
      "**/dist/**",
      "**/coverage/**",
      "**/*.min.js",
      "**/package-lock.json",
      "**/pnpm-lock.yaml",
      "**/yarn.lock"
    ]
  }
}

